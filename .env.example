# LLM Provider Configuration
# Set to "anthropic" or "openai"
LLM_PROVIDER=anthropic

# Anthropic API Key (required when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI API Key (required when LLM_PROVIDER=openai)
OPENAI_API_KEY=your-openai-api-key-here

# Optional: Override default model names
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# OPENAI_MODEL=gpt-4o

# Optional: RAG and eval tuning (defaults are sensible)
# RAG_CHUNK_SIZE=512
# RAG_CHUNK_OVERLAP=50
# EVAL_THRESHOLD=0.7

# Optional: Session history storage (default: /app/data/sessions)
# SESSION_DATA_DIR=/app/data/sessions
